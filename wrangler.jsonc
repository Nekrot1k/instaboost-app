{
  "name": "instaboost-app",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/index.js",
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "grand-db",
      "database_id": "PASTE_YOUR_DATABASE_ID_HERE"
    }
  ]
}
